{
  "api_port": 8080,
  "max_concurrency": 5,
  "agent": {
    "type": "claude-code",
    "model": "claude-opus-4-6",
    "timeout": "20m",
    "max_iterations": 3,
    "prompt": "Solve this issue step by step. Write clean, testable code."
  },
  "workspace": {
    "base_path": "~/.auto-issue/workspaces"
  }
}
